<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HowToSurvive.Maui.Pages.FirstAidPage"
             Title="Emergency First Aid"
             BackgroundColor="{StaticResource Gray950}">

    <Grid VerticalOptions="CenterAndExpand" Padding="25" RowSpacing="25" RowDefinitions="Auto, *, Auto">
        <!-- Icon and Emergency Banner -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" HorizontalOptions="Center" Margin="0,0,0,10">
            <Frame BackgroundColor="{StaticResource Magenta}" CornerRadius="30" Padding="15" HeightRequest="60" WidthRequest="60" HorizontalOptions="Center" BorderColor="Transparent">
                <Label Text="+" TextColor="White" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Frame>
            <Label Text="OFF-GRID MEDICAL ASSISTANCE" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Secondary}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Question or Advice Panel -->
        <Frame Grid.Row="1" Padding="20" BackgroundColor="{StaticResource OffBlack}" BorderColor="{StaticResource Gray600}" HasShadow="True" CornerRadius="12" VerticalOptions="Center">
            <VerticalStackLayout Spacing="15" VerticalOptions="Center">
                <Label x:Name="FlowTextLabel" Text="Loading questions..." FontSize="20" FontAttributes="Bold" TextColor="{StaticResource White}" HorizontalTextAlignment="Center" LineHeight="1.3"/>
            </VerticalStackLayout>
        </Frame>

        <!-- Interactive Buttons -->
        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="15" x:Name="QuestionButtonGrid">
            <Button Grid.Column="0" Text="NO" Clicked="OnNoClicked" BackgroundColor="{StaticResource Gray600}" TextColor="White" HeightRequest="60" FontSize="18" FontAttributes="Bold" CornerRadius="8"/>
            <Button Grid.Column="1" Text="YES" Clicked="OnYesClicked" BackgroundColor="{StaticResource Secondary}" TextColor="White" HeightRequest="60" FontSize="18" FontAttributes="Bold" CornerRadius="8"/>
        </Grid>
        
        <Button Grid.Row="2" x:Name="RestartButton" Text="RESTART DIAGNOSTIC" Clicked="OnRestartClicked" BackgroundColor="{StaticResource Primary}" TextColor="White" HeightRequest="60" FontSize="18" FontAttributes="Bold" CornerRadius="8" IsVisible="False"/>
    </Grid>
</ContentPage>
