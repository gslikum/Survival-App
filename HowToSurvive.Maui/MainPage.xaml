<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HowToSurvive.Maui.MainPage"
             Title="Survival Dashboard"
             BackgroundColor="{StaticResource Gray950}">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="15">
        <!-- Dashboard Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,10">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="SAS SURVIVAL" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource White}"/>
                <Label Text="OFF-GRID TECHNICAL FIELD MANUAL" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Secondary}"/>
            </VerticalStackLayout>
            <!-- Emergency First Aid Quick Action -->
            <Button Grid.Column="1" Text="FIRST AID +" Clicked="OnEmergencyClicked" BackgroundColor="{StaticResource Magenta}" TextColor="White" FontAttributes="Bold" CornerRadius="4" HeightRequest="45" WidthRequest="110" Padding="0"/>
        </Grid>

        <!-- Main Scrollable Area -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="15">
                
                <!-- Search Bar -->
                <Frame Padding="0" BackgroundColor="{StaticResource OffBlack}" BorderColor="{StaticResource Gray600}" CornerRadius="6">
                    <Grid ColumnDefinitions="*, Auto" Padding="5,0">
                        <Entry x:Name="SearchEntry" Placeholder="Search book offline..." TextColor="{StaticResource White}" PlaceholderColor="{StaticResource Gray500}" FontSize="15" HeightRequest="40" Margin="10,0" TextChanged="OnSearchTextChanged"/>
                        <Button Grid.Column="1" Text="CLEAR" x:Name="ClearSearchBtn" Clicked="OnClearSearchClicked" IsVisible="False" BackgroundColor="Transparent" TextColor="{StaticResource Gray400}" FontAttributes="Bold" WidthRequest="80" Padding="0"/>
                    </Grid>
                </Frame>

                <!-- Search Results Area -->
                <VerticalStackLayout x:Name="SearchResultsStack" IsVisible="False" Spacing="10">
                    <Label Text="SEARCH RESULTS" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Secondary}"/>
                    <CollectionView x:Name="SearchResultsCollectionView" SelectionMode="Single" SelectionChanged="OnSearchResultSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,3">
                                    <Frame Padding="10" BackgroundColor="{StaticResource OffBlack}" BorderColor="{StaticResource Gray600}">
                                        <VerticalStackLayout>
                                            <Label Text="{Binding Article.Title}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource White}"/>
                                            <Label Text="{Binding Chapter.Title}" FontSize="11" TextColor="{StaticResource Secondary}"/>
                                        </VerticalStackLayout>
                                    </Frame>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Primary Chapters Grid (Hidden during Search) -->
                <VerticalStackLayout x:Name="ChaptersLayout" Spacing="15">
                    <Label Text="HANDBOOK CHAPTERS" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Gray400}"/>

                    <!-- 3x3 Grid for Chapters -->
                    <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, *, *" RowSpacing="10" ColumnSpacing="10">
                        <!-- Row 0 -->
                        <Frame Grid.Row="0" Grid.Column="0" Padding="0" BorderColor="{StaticResource Gray600}" BackgroundColor="{StaticResource OffBlack}" HasShadow="True" CornerRadius="8">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChapterTapped" CommandParameter="Essentials"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="*, Auto" HeightRequest="100">
                                <Image Grid.Row="0" Source="essentials.jpg" Aspect="AspectFill" Opacity="0.65"/>
                                <Label Grid.Row="1" Text="ESSENTIALS" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="5"/>
                            </Grid>
                        </Frame>

                        <Frame Grid.Row="0" Grid.Column="1" Padding="0" BorderColor="{StaticResource Gray600}" BackgroundColor="{StaticResource OffBlack}" HasShadow="True" CornerRadius="8">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChapterTapped" CommandParameter="Strategy"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="*, Auto" HeightRequest="100">
                                <Image Grid.Row="0" Source="strategy.jpg" Aspect="AspectFill" Opacity="0.65"/>
                                <Label Grid.Row="1" Text="STRATEGY" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="5"/>
                            </Grid>
                        </Frame>

                        <Frame Grid.Row="0" Grid.Column="2" Padding="0" BorderColor="{StaticResource Gray600}" BackgroundColor="{StaticResource OffBlack}" HasShadow="True" CornerRadius="8">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChapterTapped" CommandParameter="Climate &amp; Terrain"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="*, Auto" HeightRequest="100">
                                <Image Grid.Row="0" Source="climate.jpg" Aspect="AspectFill" Opacity="0.65"/>
                                <Label Grid.Row="1" Text="CLIMATE" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="5"/>
                            </Grid>
                        </Frame>

                        <!-- Row 1 -->
                        <Frame Grid.Row="1" Grid.Column="0" Padding="0" BorderColor="{StaticResource Gray600}" BackgroundColor="{StaticResource OffBlack}" HasShadow="True" CornerRadius="8">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChapterTapped" CommandParameter="Food Procurement"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="*, Auto" HeightRequest="100">
                                <Image Grid.Row="0" Source="food.jpg" Aspect="AspectFill" Opacity="0.65"/>
                                <Label Grid.Row="1" Text="FOOD" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="5"/>
                            </Grid>
                        </Frame>

                        <Frame Grid.Row="1" Grid.Column="1" Padding="0" BorderColor="{StaticResource Gray600}" BackgroundColor="{StaticResource OffBlack}" HasShadow="True" CornerRadius="8">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChapterTapped" CommandParameter="Camp Craft"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="*, Auto" HeightRequest="100">
                                <Image Grid.Row="0" Source="campcraft.jpg" Aspect="AspectFill" Opacity="0.65"/>
                                <Label Grid.Row="1" Text="CAMPCRAFT" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="5"/>
                            </Grid>
                        </Frame>

                        <Frame Grid.Row="1" Grid.Column="2" Padding="0" BorderColor="{StaticResource Gray600}" BackgroundColor="{StaticResource OffBlack}" HasShadow="True" CornerRadius="8">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChapterTapped" CommandParameter="Reading the Signs"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="*, Auto" HeightRequest="100">
                                <Image Grid.Row="0" Source="navigation.jpg" Aspect="AspectFill" Opacity="0.65"/>
                                <Label Grid.Row="1" Text="NAVIGATION" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="5"/>
                            </Grid>
                        </Frame>

                        <!-- Row 2 -->
                        <Frame Grid.Row="2" Grid.Column="0" Padding="0" BorderColor="{StaticResource Gray600}" BackgroundColor="{StaticResource OffBlack}" HasShadow="True" CornerRadius="8">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChapterTapped" CommandParameter="On the Move"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="*, Auto" HeightRequest="100">
                                <Image Grid.Row="0" Source="travel.jpg" Aspect="AspectFill" Opacity="0.65"/>
                                <Label Grid.Row="1" Text="TRAVEL" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="5"/>
                            </Grid>
                        </Frame>

                        <Frame Grid.Row="2" Grid.Column="1" Padding="0" BorderColor="{StaticResource Gray600}" BackgroundColor="{StaticResource OffBlack}" HasShadow="True" CornerRadius="8">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChapterTapped" CommandParameter="Health"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="*, Auto" HeightRequest="100">
                                <Image Grid.Row="0" Source="health.jpg" Aspect="AspectFill" Opacity="0.65"/>
                                <Label Grid.Row="1" Text="HEALTH" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="5"/>
                            </Grid>
                        </Frame>

                        <Frame Grid.Row="2" Grid.Column="2" Padding="0" BorderColor="{StaticResource Gray600}" BackgroundColor="{StaticResource OffBlack}" HasShadow="True" CornerRadius="8">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChapterTapped" CommandParameter="Disaster Survival"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="*, Auto" HeightRequest="100">
                                <Image Grid.Row="0" Source="disaster.jpg" Aspect="AspectFill" Opacity="0.65"/>
                                <Label Grid.Row="1" Text="DISASTERS" TextColor="White" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="5"/>
                            </Grid>
                        </Frame>
                    </Grid>

                    <!-- SOS Signaler Quick Action -->
                    <Frame BorderColor="{StaticResource Gray600}" BackgroundColor="{StaticResource OffBlack}" Padding="15" Margin="0,10,0,0">
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Emergency Signaling" FontSize="16" FontAttributes="Bold" TextColor="White"/>
                                <Label Text="Access visual SOS flash and Morse codes." FontSize="12" TextColor="{StaticResource Gray400}"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="SIGNALER" Clicked="OnSignalerClicked" BackgroundColor="{StaticResource Secondary}" TextColor="White" FontAttributes="Bold" CornerRadius="4"/>
                        </Grid>
                    </Frame>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
